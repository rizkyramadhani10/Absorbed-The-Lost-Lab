[resource]
script = ExtResource("1_sjhy8")
question_text = "Saat memanaskan cairan di dalam tabung reaksi menggunakan pembakar spiritus, ke mana arah mulut tabung reaksi harus dihadapkan?"
choices = Array[String](["Menghadap langsung ke wajah sendiri agar bisa mengamati perubahan warna dengan jelas", "Menghadap ke arah teman kelompok di sebelah agar mereka bisa melihatnya", "Menghadap ke arah area kosong yang tidak ada orang atau fasilitas sensitif", "Menghadap ke bawah lantai tepat di dekat kaki praktikan"])
correct_choice_index = 2
