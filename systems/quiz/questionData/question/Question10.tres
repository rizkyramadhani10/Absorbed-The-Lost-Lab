[resource]
script = ExtResource("1_jt37m")
question_text = "Mengapa zat kimia organik berbahaya (seperti kloroform) mutlak tidak boleh dibuang ke saluran air umum/wastafel?"
choices = Array[String](["Karena zat tersebut dapat menguap dan membuat saluran air menjadi wangi", "Karena dapat merusak pipa saluran serta mencemari lingkungan dan ekosistem air dengan racun persisten", "Karena zat tersebut bisa membeku dan menyumbat total aliran air wastafel", "Karena zat organik akan bereaksi dengan air dan berubah menjadi emas cair"])
correct_choice_index = 1
