[resource]
script = ExtResource("1_fekkn")
question_text = "Mengapa kita tidak boleh mengisi tabung reaksi hingga penuh saat hendak memanaskan larutan di dalamnya?"
choices = Array[String](["Agar larutan tidak terlalu cepat dingin saat diangkat dari api", "Untuk mencegah larutan tumpah atau mencuat keluar (bumping) akibat tekanan uap saat mendidih", "Supaya tabung reaksi tidak pecah karena terlalu berat menampung beban cairan", "Agar warna larutan tidak memudar akibat panas yang berlebihan"])
correct_choice_index = 1
